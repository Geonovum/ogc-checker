{
  "name": "@geonovum/ogc-checker",
  "version": "1.0.0-beta.1",
  "packageManager": "pnpm@10.11.0",
  "license": "EUPL-1.2",
  "type": "module",
  "bin": {
    "ogc-checker": "./dist/cli.js"
  },
  "scripts": {
    "dev": "vite --open",
    "build": "tsc -b && pnpm run build:cli && vite build",
    "build:cli": "tsdown src/cli.ts --format esm --platform node --sourcemap --out-dir dist --clean",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "test": "vitest"
  },
  "dependencies": {
    "@geonovum/standards-checker": "^1.0.0-beta.5",
    "@geonovum/standards-checker-ui": "^1.0.0-beta.5",
