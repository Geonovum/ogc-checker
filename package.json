    "luxon": "^3.7.2",
    "ramda": "^0.32.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/luxon": "^3.7.1",
    "@types/ramda": "^0.31.1",
    "eslint": "^9.39.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
