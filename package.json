{
  "name": "@geonovum/ogc-checker",
  "version": "1.0.4",
  "packageManager": "pnpm@10.33.0",
  "license": "EUPL-1.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/Geonovum/ogc-checker"
  },
  "engines": {
    "node": ">=20.17"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "bin": {
    "ogc-checker": "./dist/cli.mjs"
  },
  "scripts": {
    "dev": "vite --open",
    "build": "tsc -b && pnpm run build:cli && vite build",
    "build:cli": "build-cli src/cli.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "test": "vitest"
  },
  "prettier": "@geonovum/standards-checker/prettier",
  "dependencies": {
    "@geonovum/standards-checker": "^1.1.4",
    "luxon": "^3.7.2",
    "ramda": "^0.32.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/ramda": "^0.31.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
